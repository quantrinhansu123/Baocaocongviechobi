
# Supabase — toàn bộ dữ liệu (công việc I.1 … IV.2 + BC định kỳ), server-side only.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
# Tùy chọn: đổi tên bảng Postgres (mặc định i_1, ii_4, bc_dinh_ky, …)
# SUPABASE_TABLE_I_1="i_1"
# SUPABASE_TABLE_II_4="ii_4"
# SUPABASE_TABLE_BC_DINH_KY="bc_dinh_ky"
